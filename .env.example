PORT=3000
NODE_ENV=development
SESSION_SECRET=change-this-to-a-random-secret-string
APP_URL=http://localhost:3000

# Stripe (optional — billing works in dev mode without these)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=
STRIPE_POWERHOUSE_PRICE_ID=
STRIPE_ENTERPRISE_PRICE_ID=

# Email (SMTP — optional, notifications log to console without these)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=messages@dirtlink.ca

# Twilio SMS (optional — SMS notifications disabled without these)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Admin secret for API key provisioning (POST /api/admin/create-key)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SECRET=
